WC_APP_NAME="足球赛事 AI 推演引擎"
WC_DATA_PATH=./data/demo_matches.json
WC_RUNS_PATH=./runs
WC_SKILL_PATH=~/.hermes/skills/leisure/worldcup2026-betting-analyst
WC_MAX_RUN_MATCHES=8
WC_MAX_CONCURRENT_RUNS=1
WC_DEFAULT_COMMAND_TIMEOUT=60
WC_DB_PATH=./data/app.db
# Desktop beta mode stores mutable user data under WC_APP_DATA_DIR unless explicit paths above/below override it.
# Use WC_DESKTOP_MODE=1 for packaged desktop runs; leave disabled for source/development runs.
WC_DESKTOP_MODE=0
# WC_APP_DATA_DIR=
# WC_CONFIG_PATH=
# WC_LOGS_PATH=
# WC_API_KEY_STORAGE_MODE=keychain
# `scripts/start.sh` and `Dockerfile` refuse unsafe external binding unless WC_API_TOKEN is set.
# For first external-user trials, keep WC_HOST=127.0.0.1 and access through SSH/Tailscale tunnel when possible.
WC_HOST=127.0.0.1
WC_API_TOKEN=
WC_PLAN=internal
WC_RUN_QUOTA=1000
WC_AUTH_MODE=token
